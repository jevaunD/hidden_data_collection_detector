{
  "manifest_version": 3,
  "name": "Autofill Detector",
  "version": "1.0",
  "description": "Detects suspicious autofill behavior on webpages.",
  "permissions": ["scripting", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches":  [
        "*://*/*login*",
        "*://*/*signin*",
        "*://*/*signup*",
        "*://*/*register*",
        "*://*/*account*",
        "*://*/*auth*",
        "*://*/*checkout*",
        "*://*/*payment*",
        "*://*/*sign_in",
        "*://*/*login*",
        "*://*/*signin*",
        "*://*/*auth*",
        "https://autofill-danger-1.netlify.app/", 
        "*://*/*" # ---->This triggers the extension to run on any web page that is loaded. You can remove this line 
                  # and either keep the lines that include login and signup etc or add a url pattern that will 
                  #trigger on the sites you are more skeptic about.
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}


